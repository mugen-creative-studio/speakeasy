{
  "name": "speakeasy-monorepo",
  "version": "0.1.2",
  "private": true,
  "description": "Confidential content variants behind unguessable slugs - stack-agnostic core, server adapters, and CLI (with a standalone browser dashboard).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "author": "Mugen Creative Studio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mugen-creative-studio/speakeasy.git"
  },
  "homepage": "https://github.com/mugen-creative-studio/speakeasy#readme",
  "bugs": "https://github.com/mugen-creative-studio/speakeasy/issues",
  "workspaces": [
    "packages/core",
    "packages/server",
    "packages/cli",
    "examples/demo"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "version:bump": "node scripts/bump.mjs",
    "prerelease": "npm run format:check && npm test",
    "release": "npm publish --workspaces"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
